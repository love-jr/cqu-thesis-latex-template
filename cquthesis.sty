\newcommand{\cqusetheader}[1]{%
  \fancyhf{}%
  \fancyfoot[C]{\zihao{-5}\thepage}%
  \if@twoside
    \fancyhead[CE]{\songti\zihao{-5}重庆大学本科学生毕业论文（设计）}%
    \fancyhead[CO]{\songti\zihao{-5}#1}%
  \else
    \fancyhead[L]{\songti\zihao{-5}重庆大学本科学生毕业论文（设计）}%
    \fancyhead[R]{\songti\zihao{-5}#1}%
  \fi
  \pagestyle{fancy}%
}
\makeatother

